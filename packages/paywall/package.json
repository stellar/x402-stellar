{
  "name": "@x402-stellar/paywall",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "tsx src/browser/build.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ignore-pattern src/browser/",
    "lint:fix": "eslint src/ --ignore-pattern src/browser/ --fix"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./stellar": {
      "import": "./dist/stellar.js",
      "types": "./dist/stellar.d.ts"
    }
  },
  "dependencies": {
    "@x402/core": "workspace:*"
  },
  "devDependencies": {
    "@craftamap/esbuild-plugin-html": "^0.9.0",
    "@creit.tech/stellar-wallets-kit": "^2.0.0",
    "@stellar/stellar-sdk": "^14.5.0",
    "@types/node": "^22.19.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@x402/stellar": "workspace:*",
    "buffer": "^6.0.3",
    "esbuild": "^0.25.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
