# Agent's Stellar secret key (starts with 'S', 56 characters)
AGENT_STELLAR_PRIVATE_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL of the x402-protected resource to access
# Use the /api/protected/* paths for JSON responses (no browser paywall)
TARGET_URL=http://localhost:3001/api/protected/testnet

# Optional: Custom Soroban RPC URL (defaults to the public SDF testnet endpoint)
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Optional: Maximum number of payment signing retries (default: 3)
# MAX_RETRIES=3
