# Facilitator
FACILITATOR_STELLAR_PRIVATE_KEY=S_YOUR_FACILITATOR_PRIVATE_KEY_HERE
PORT=4022

# Stellar
STELLAR_NETWORK=stellar:testnet
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# High-throughput mode (optional)
# Use a separate fee-bump signer and channel accounts for parallel tx submission.
# Run: pnpm generate-channels  (to generate and fund these on testnet)
# FACILITATOR_STELLAR_FEE_BUMP_SECRET=S_YOUR_FEE_BUMP_SECRET_HERE
# FACILITATOR_STELLAR_CHANNEL_SECRETS=S_CHANNEL_1,S_CHANNEL_2,...,S_CHANNEL_N

# Transaction fee cap (stroops). The @x402/stellar library default is 50,000
# but Soroban resource fees can exceed that. Set higher if clients get
# "fee_exceeds_maximum" errors.
# MAX_TRANSACTION_FEE_STROOPS=100000

# Security
# TRUST_PROXY=loopback,linklocal,uniquelocal
# CORS_ORIGINS=http://localhost:3001
# Optional: Bearer token that clients must send in Authorization header.
# When unset the facilitator is open (suitable for local/private networks only).
# FACILITATOR_API_KEY=your-secret-key-here
