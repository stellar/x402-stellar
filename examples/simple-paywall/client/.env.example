# Server URL for API requests (runtime-configurable in Docker via docker-entrypoint.sh)
# VITE_SERVER_URL=http://localhost:3001

# Display name shown in the UI (runtime-configurable in Docker)
# VITE_APP_NAME=x402 on Stellar

# Payment price shown in the UI (runtime-configurable in Docker)
# VITE_PAYMENT_PRICE=0.01

# Vite dev server port (build-time only, not used in Docker)
# VITE_PORT=5173
