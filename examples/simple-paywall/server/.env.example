# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
CLIENT_HOME_URL=http://localhost:5173

# Set to "true" to disable the paywall and serve protected content freely
# PAYWALL_DISABLED=true
PAYMENT_PRICE=0.01

# ── Stellar Testnet ────────────────────────────────────────────────────
# Provide TESTNET_* variables to enable /protected/testnet endpoint.
TESTNET_SERVER_STELLAR_ADDRESS=G_YOUR_TESTNET_STELLAR_ADDRESS_HERE
# TESTNET_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
TESTNET_FACILITATOR_URL=http://localhost:4022
# TESTNET_FACILITATOR_API_KEY=your-testnet-api-key-here

# ── Stellar Mainnet ────────────────────────────────────────────────────
# Provide MAINNET_* variables to enable /protected/mainnet endpoint.
# MAINNET_SERVER_STELLAR_ADDRESS=G_YOUR_MAINNET_STELLAR_ADDRESS_HERE
# MAINNET_STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
# MAINNET_FACILITATOR_URL=https://channels.openzeppelin.com/x402
# MAINNET_FACILITATOR_API_KEY=your-mainnet-api-key-here

# Security
# TRUST_PROXY=loopback,linklocal,uniquelocal
