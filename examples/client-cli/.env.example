# Stellar secret key for a funded testnet account.
# Generate and fund one at https://lab.stellar.org/account/create
# Then add a USDC trustline and get testnet USDC from https://faucet.circle.com/
STELLAR_PRIVATE_KEY=S...

# Base URL of the simple-paywall server
SERVER_URL=http://localhost:3001

# Network to use: "testnet" or "mainnet"
NETWORK=testnet
