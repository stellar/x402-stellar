# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# Set to "true" to disable the paywall and serve protected content freely
# PAYWALL_DISABLED=true

# Stellar
SERVER_STELLAR_ADDRESS=G_YOUR_SERVER_STELLAR_ADDRESS_HERE
STELLAR_NETWORK=stellar:testnet
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org
PAYMENT_PRICE=0.01

# Facilitator (use the x402 repo's facilitator)
FACILITATOR_URL=http://localhost:4022
# FACILITATOR_API_KEY=your-api-key-here

# Facilitator
FACILITATOR_STELLAR_PRIVATE_KEY=S_YOUR_FACILITATOR_PRIVATE_KEY_HERE

# High-throughput mode (optional, facilitator only)
# FACILITATOR_STELLAR_FEE_BUMP_SECRET=S_YOUR_FEE_BUMP_SECRET_HERE
# FACILITATOR_STELLAR_CHANNEL_SECRETS=S_CHANNEL_1,S_CHANNEL_2,...,S_CHANNEL_N

# Security
# TRUST_PROXY=loopback,linklocal,uniquelocal

# Client SPA (used at build time with Vite, or at runtime via docker-entrypoint.sh)
# VITE_SERVER_URL=http://localhost:3001
# VITE_APP_NAME=x402 on Stellar
