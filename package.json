{
  "name": "x402-stellar",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "build": "turbo run build --filter='@x402-stellar/*'",
    "dev": "turbo run dev --filter='@x402-stellar/*'",
    "lint": "turbo run lint --filter='@x402-stellar/*'",
    "lint:fix": "turbo run lint:fix --filter='@x402-stellar/*'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck --filter='@x402-stellar/*'",
    "test": "turbo run test --filter='@x402-stellar/*'"
  },
  "pnpm": {
    "patchedDependencies": {
      "@creit.tech/stellar-wallets-kit@2.0.0": "patches/@creit.tech__stellar-wallets-kit@2.0.0.patch"
    },
    "overrides": {
