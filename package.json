{
  "name": "x402-stellar",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build --filter='@x402-stellar/*'",
    "dev": "turbo run dev --filter='@x402-stellar/*'",
    "lint": "turbo run lint --filter='@x402-stellar/*'",
    "lint:fix": "turbo run lint:fix --filter='@x402-stellar/*'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck --filter='@x402-stellar/*'",
    "test": "turbo run test --filter='@x402-stellar/*'"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "typescript": "^5.9.3",
      "axios": "^1.15.0",
      "protobufjs": "^7.5.5",
      "follow-redirects": "^1.16.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
